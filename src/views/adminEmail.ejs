<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body { margin: 0; padding: 20px; background-color: #f4f4f4; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .container { max-width: 600px; margin: 0 auto; background: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        .alert-header { background-color: #1c1917; color: #BFA13B; padding: 25px; text-align: center; }
        .badge { background: #BFA13B; color: white; padding: 4px 12px; border-radius: 20px; font-size: 10px; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; }
        .content { padding: 30px; }
        .section-title { font-size: 12px; font-weight: bold; color: #8e7421; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 15px; border-bottom: 1px solid #eee; padding-bottom: 5px; margin-top: 20px; }
        .info-grid { width: 100%; border-collapse: collapse; }
        .info-label { font-size: 13px; color: #78716c; width: 120px; padding: 8px 0; vertical-align: top; }
        .info-value { font-size: 14px; color: #1c1917; font-weight: 600; padding: 8px 0; }
        .message-box { background-color: #fdf8ec; border-left: 4px solid #BFA13B; padding: 20px; border-radius: 4px; color: #444; line-height: 1.6; font-style: italic; margin-top: 10px; }
        .footer { background: #f9f8f6; padding: 15px; text-align: center; font-size: 11px; color: #a8a29e; }
        .btn { display: inline-block; padding: 12px 25px; background-color: #BFA13B; color: white !important; text-decoration: none; border-radius: 8px; font-weight: bold; font-size: 13px; margin-top: 25px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="alert-header">
            <span class="badge">🚨 New Lead</span>
            <h2 style="margin: 10px 0 0 0; letter-spacing: 1px; color: #BFA13B;">Inquiry Received</h2>
        </div>

        <div class="content">
            <div class="section-title">Client Profile</div>
            <table class="info-grid">
                <tr>
                    <td class="info-label">Name:</td>
                    <td class="info-value"><%= data.name %></td>
                </tr>
                <tr>
                    <td class="info-label">Email:</td>
                    <td class="info-value"><a href="mailto:<%= data.email %>" style="color: #BFA13B; text-decoration: none;"><%= data.email %></a></td>
                </tr>
                <tr>
                    <td class="info-label">Phone:</td>
                    <td class="info-value"><%= data.phone %></td>
                </tr>
            </table>

            <div class="section-title">Booking Preferences</div>
            <table class="info-grid">
                <tr>
                    <td class="info-label">Destination:</td>
                    <td class="info-value"><%= data.place %></td>
                </tr>
                <tr>
                    <td class="info-label">Travel Date:</td>
                    <td class="info-value"><%= data.date %></td>
                </tr>
                <tr>
                    <td class="info-label">Passengers:</td>
                    <td class="info-value"><%= data.passengers %> Guests</td>
                </tr>
            </table>

            <div class="section-title">Personal Message</div>
            <div class="message-box">
                "<%= data.message %>"
            </div>

            <div style="text-align: center;">
                <a href="mailto:<%= data.email %>" class="btn">Respond to Inquiry</a>
            </div>
        </div>

        <div class="footer">
            Internal Notification • Luxury Concierge Web Portal<br>
            Generated on <%= new Date().toLocaleString() %>
        </div>
    </div>
</body>
</html>